---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="搜索">
  <div class="max-w-3xl mx-auto">
    <header class="mb-12 text-center" transition:animate="fade">
      <h1 class="text-5xl mb-4">搜索</h1>
      <p class="text-xl text-muted-foreground">
        在周刊文章中查找内容
      </p>
    </header>

    <div transition:animate="fade">
      <form id="search-form" class="relative mb-8" action="/search" method="get">
      <input
        id="search-input"
        name="q"
        type="text"
        placeholder="输入关键词..."
        class="w-full px-5 py-3.5 pl-12 pr-24 text-base bg-white dark:bg-black border border-gray-300 dark:border-gray-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-gray-900 dark:focus:ring-gray-100 focus:border-transparent transition-shadow"
        autocomplete="off"
      />
      <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
      </svg>
      <button
        type="submit"
        class="absolute right-2 top-1/2 -translate-y-1/2 px-4 py-1.5 text-sm font-medium bg-gray-900 dark:bg-gray-100 text-white dark:text-black rounded-md hover:bg-gray-700 dark:hover:bg-gray-300 transition-colors"
      >
        搜索
      </button>
    </form>

    <div id="search-status" class="text-sm text-gray-500 dark:text-gray-400 mb-4"></div>

    <div id="search-results" class="space-y-6">
      <div class="text-center py-16 text-gray-400 dark:text-gray-600">
        <svg class="mx-auto w-12 h-12 mb-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
        </svg>
        <p>输入关键词开始搜索</p>
      </div>
    </div>
    </div>
  </div>
</BaseLayout>

<script>
  let index = [];
  let indexLoaded = false;
  let debounceTimer;

  async function loadIndex() {
    if (indexLoaded) return;
    try {
      const res = await fetch('/search-index.json');
      if (!res.ok) throw new Error('HTTP ' + res.status);
      index = await res.json();
      indexLoaded = true;
      updateStatus('');
    } catch (e) {
      console.error('加载搜索索引失败', e);
      updateStatus('索引加载失败，请刷新页面重试');
    }
  }

  function updateStatus(msg) {
    const el = document.getElementById('search-status');
    if (msg) {
      el.textContent = msg;
      el.classList.remove('hidden');
    } else {
      el.classList.add('hidden');
    }
  }

  function highlight(text, query) {
    const regex = new RegExp(`(${escapeRegExp(query)})`, 'gi');
    return text.replace(regex, '<mark class="bg-yellow-200 dark:bg-yellow-900 px-0.5 rounded">$1</mark>');
  }

  function escapeRegExp(string) {
    return string.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  }

  function getExcerpt(text, query, maxLen = 160) {
    const lower = text.toLowerCase();
    const idx = lower.indexOf(query.toLowerCase());
    if (idx === -1) return text.slice(0, maxLen) + (text.length > maxLen ? '...' : '');

    const start = Math.max(0, idx - 60);
    const end = Math.min(text.length, idx + maxLen);
    let excerpt = text.slice(start, end);
    if (start > 0) excerpt = '...' + excerpt;
    if (end < text.length) excerpt = excerpt + '...';
    return excerpt;
  }

  function performSearch(query) {
    const resultsEl = document.getElementById('search-results');

    if (!query.trim()) {
      resultsEl.innerHTML = `
        <div class="text-center py-16 text-gray-400 dark:text-gray-600">
          <svg class="mx-auto w-12 h-12 mb-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
          </svg>
          <p>输入关键词开始搜索</p>
        </div>`;
      updateStatus('');
      return;
    }

    if (!indexLoaded || index.length === 0) {
      resultsEl.innerHTML = `
        <div class="text-center py-16 text-gray-400 dark:text-gray-600">
          <p>索引加载中，请稍后再试...</p>
        </div>`;
      return;
    }

    const q = query.trim().toLowerCase();
    const results = index
      .map(item => {
        let score = 0;
        const title = ((item.displayTitle || item.title) || '').toLowerCase();
        const desc = (item.description || '').toLowerCase();
        const content = (item.content || '').toLowerCase();
        const tags = (item.tags || []).join(' ').toLowerCase();

        if (title.includes(q)) score += 10;
        if (desc.includes(q)) score += 5;
        if (tags.includes(q)) score += 4;
        if (content.includes(q)) score += 2;

        return { item, score };
      })
      .filter(r => r.score > 0)
      .sort((a, b) => b.score - a.score);

    updateStatus(`找到 ${results.length} 个结果`);

    if (results.length === 0) {
      resultsEl.innerHTML = `
        <div class="text-center py-16 text-gray-400 dark:text-gray-600">
          <p>未找到与 "<span class="font-medium text-gray-600 dark:text-gray-400">${escapeHtml(q)}</span>" 相关的结果</p>
        </div>`;
      return;
    }

    resultsEl.innerHTML = results.map(({ item }) => {
      const excerpt = getExcerpt((item.content || '') + ' ' + (item.description || ''), q, 140);
      const dateStr = item.date ? new Date(item.date).toLocaleDateString('zh-CN') : '';
      const tagsHtml = (item.tags || []).map(t =>
        `<span class="inline-block text-xs px-2 py-0.5 bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 rounded">${escapeHtml(t)}</span>`
      ).join(' ');

      return `
        <article class="group">
          <a href="/weekly/${item.slug}/" class="block p-5 rounded-xl border border-gray-200 dark:border-gray-800 hover:border-gray-400 dark:hover:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-900/50 transition-all">
            <div class="flex items-start justify-between gap-4 mb-2">
              <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 group-hover:underline decoration-2 underline-offset-2">${highlight(escapeHtml(item.displayTitle || item.title || ''), q)}</h2>
              ${dateStr ? `<time class="text-sm text-gray-400 dark:text-gray-600 whitespace-nowrap flex-shrink-0">${dateStr}</time>` : ''}
            </div>
            <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-2 mb-3">${highlight(escapeHtml(excerpt), q)}</p>
            ${tagsHtml ? `<div class="flex flex-wrap gap-2">${tagsHtml}</div>` : ''}
          </a>
        </article>
      `;
    }).join('');
  }

  function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  const input = document.getElementById('search-input');
  const form = document.getElementById('search-form');

  input.addEventListener('input', (e) => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => performSearch(e.target.value), 200);
  });

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    clearTimeout(debounceTimer);
    performSearch(input.value);
  });

  // 初始化：先加载索引，再处理 URL 参数
  loadIndex().then(() => {
    const urlParams = new URLSearchParams(window.location.search);
    const q = urlParams.get('q');
    if (q) {
      input.value = q;
      performSearch(q);
    }
  });
</script>
