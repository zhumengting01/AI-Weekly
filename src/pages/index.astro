---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostList from '../components/PostList.astro';
import { getCollection } from 'astro:content';
import { getWeekTitle } from '../utils/date';

// 获取最新周刊
const allWeekly = await getCollection('weekly');
const sortedWeekly = allWeekly.sort((a, b) => {
  return new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf();
});
const latestWeekly = sortedWeekly.slice(0, 3).map(post => ({
  ...post,
  url: `/weekly/${post.id}`,
  frontmatter: { ...post.data, title: getWeekTitle(post.data.date) }
}));

// 获取博客文章
const allPosts = await getCollection('posts');
const sortedPosts = allPosts.sort((a, b) => {
  return new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf();
});
const posts = sortedPosts.slice(0, 5).map(post => ({
  ...post,
  url: `/posts/${post.id}`,
  frontmatter: post.data
}));
---

<BaseLayout title="欢迎">
  <div class="max-w-4xl mx-auto">
    <section class="text-center py-[8vh]" transition:animate="fade">
      <h1 class="text-7xl mb-8 font-bold">欢迎来到 AI Weekly</h1>
      <p class="text-2xl text-muted-foreground max-w-3xl mx-auto mb-14">
        每周精选 AI 领域热点新闻、工具推荐和开源项目
      </p>
      <a href="/weekly" class="btn-primary btn-lg tracking-wide no-underline hover:no-underline transform transition-all duration-300 hover:scale-105 hover:shadow-[0_3.5rem_5rem_rgba(21,21,21,0.3)] shadow-[0_3rem_4rem_rgba(21,21,21,0.25)] dark:bg-white dark:text-black dark:hover:bg-gray-100">
        阅读最新周刊
      </a>
    </section>

    {latestWeekly.length > 0 && (
      <section class="mx-auto mb-16" transition:animate="fade">
        <PostList posts={latestWeekly} showExcerpt={true} showTags={true} title="最新周刊" />

        <div class="text-center mt-12">
          <a href="/weekly" class="text-lg font-medium text-black dark:text-white py-2 px-4 rounded-md inline-block focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 hover:underline">
            查看所有周刊 <span aria-hidden="true">→</span>
          </a>
        </div>
      </section>
    )}

    {posts.length > 0 && (
      <section class="mx-auto" transition:animate="fade">
        <PostList posts={posts} showImages={false} showExcerpt={false} showSeparators={true} showTags={false}/>

        <div class="text-center mt-24">
          <a href="/journal" class="text-lg font-medium text-black dark:text-white py-2 px-4 rounded-md inline-block focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 hover:underline">
            查看所有文章 <span aria-hidden="true">→</span>
          </a>
        </div>
      </section>
    )}
  </div>
</BaseLayout>
